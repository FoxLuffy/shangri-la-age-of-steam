# ==============================================================================
# Shangri-la: Age of Steam - Environment Variables Template
# Copy this file to '.env' and fill in your values.
# ==============================================================================

# Project metadata
PROJECT_NAME=shangri-la

# Ports configuration
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Directory where persistent database and assets will be stored
# For local dev: defaults to './saos_data' in the project directory
# For TrueNAS SCALE: e.g., '/mnt/tank/saos_data'
SAOS_DATA_DIR=./saos_data

# vLLM/Inference backend configuration
# The endpoint where the narrative engine should send its prompt requests
VLLM_API_BASE=http://localhost:8000/v1
# API key for the vLLM server (leave as NONE if no authentication is required)
VLLM_API_KEY=NONE
